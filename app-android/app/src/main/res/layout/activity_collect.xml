<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Compact header toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Voltar" />

        <TextView
            android:id="@+id/tvBoxHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:paddingStart="4dp" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF" />

    </LinearLayout>

    <!-- SKU info line -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/bg">

        <TextView
            android:id="@+id/tvSkuRef"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="   COR: "
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvSkuCor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="   TAM: "
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvSkuTam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- Address block (big) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center"
        android:padding="20dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

    </LinearLayout>

    <!-- Quantity -->
    <TextView
        android:id="@+id/tvQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="center"
        android:padding="12dp" />

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

    <!-- Scan feedback overlay text (invisible normally) -->
    <TextView
        android:id="@+id/tvScanFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@color/success"
        android:visibility="gone" />

    <!-- Hidden EditText to capture barcode from hardware scanner -->
    <EditText
        android:id="@+id/etBarcodeCapture"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:inputType="text"
        android:imeOptions="flagNoExtractUi"
        android:importantForAutofill="no"
        android:alpha="0" />

    <!-- Last reads label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_last_reads"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <!-- Last reads list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLastReads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never" />

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg">

        <Button
            android:id="@+id/btnSkipSku"
            style="@style/KollectaOps.Button.Outline"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/btn_skip_sku"
            android:textSize="12sp" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider" />

        <Button
            android:id="@+id/btnSeePositions"
            style="@style/KollectaOps.Button.Outline"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/btn_see_positions"
            android:textSize="12sp" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider" />

        <Button
            android:id="@+id/btnSavePartial"
            style="@style/KollectaOps.Button.Outline"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/btn_save_partial"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
